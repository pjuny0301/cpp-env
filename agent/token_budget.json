{
  "schema_version": 1,
  "read_first": [
    "agent/shared_command.json",
    "agent/token_budget.json",
    "bootstrap/codex_env/defaults/local_agent_policy.json"
  ],
  "working_set": [
    ".gitignore",
    "AGENTS.md",
    "README.md",
    "agent/",
    "bootstrap/",
    "plan/"
  ],
  "ignore_by_default": [
    ".git/",
    "mcp/",
    "quiz/"
  ],
  "hard_skip_globs": [
    "**/src-tauri/target-codex-build/**",
    "**/src-tauri/target-codex-desktop/**",
    "**/build-artifacts/**"
  ],
  "generated_or_large_text_rules": [
    {
      "paths": [
        "**/package-lock.json"
      ],
      "policy": "Read only for dependency or install-version issues."
    },
    {
      "paths": [
        "**/src-tauri/gen/schemas/**"
      ],
      "policy": "Treat as generated output. Read source config first and delegate summarization when possible."
    },
    {
      "paths": [
        "plan/*/plan_summary.docx",
        "plan/*/plan_summary.pdf"
      ],
      "policy": "Avoid unless the task is layout or render verification."
    }
  ],
  "tool_discovery_read_order": [
    "C:/codex-local/registry/tool-registry.json",
    "C:/codex-local/tools/*/tool.json",
    "C:/codex-local/tools/*/README.md"
  ]
}
