{
  "schema_version": 1,
  "purpose": "Single-file handoff for the main agent and any trusted local sub-agents working in this repo.",
  "read_first": [
    "codex/common/agent/shared_command.json",
    "codex/common/agent/token_budget.json",
    "AGENTS.md",
    "build/external/tools/bootstrap/codex_env/defaults/local_agent_policy.json"
  ],
  "subtree_guides": {
    "codex": "codex/AGENTS.md",
    "codex_common": "codex/common/AGENTS.md",
    "codex_agent": "codex/common/agent/AGENTS.md",
    "codex_quiz": "codex/quiz/AGENTS.md",
    "build": "build/AGENTS.md",
    "bootstrap": "build/external/tools/bootstrap/AGENTS.md",
    "apps_quiz_context": "codex/quiz/app-context/AGENTS.md",
    "apps_quiz_vulkan": "apps/quiz/quiz-vulkan/AGENTS.md"
  },
  "working_set": [
    ".gitignore",
    "AGENTS.md",
    "codex/common/",
    "codex/quiz/",
    "build/external/",
    "apps/"
  ],
  "ignore_by_default": [
    "build/out/",
    "build/external/quiz/dependencies/",
    "build/external/quiz/legacy/",
    "codex/common/mcp/",
    ".git/"
  ],
  "bootstrap_entrypoints": {
    "setup_script": "build/external/tools/bootstrap/setup_codex_env.ps1",
    "installer": "build/external/tools/bootstrap/install_codex_env.py"
  },
  "new_machine_install_contract": [
    "Ask the user for scaffold command name, plan command name, and delegation mode.",
    "Install only the Codex-specific command environment under C:/codex-local and C:/dev.",
    "Do not treat bootstrap as a whole-machine reset."
  ],
  "plan_bundle_read_order": [
    "codex/quiz/일자별요구사항/2026-04-27/generated/plan-doc/bundle_manifest.json",
    "codex/quiz/일자별요구사항/2026-04-27/generated/plan-doc/prompt_overrides.json",
    "codex/quiz/일자별요구사항/2026-04-27/generated/plan-doc/render_spec.json",
    "codex/quiz/일자별요구사항/2026-04-27/generated/plan-doc/prompts.json",
    "codex/quiz/일자별요구사항/2026-04-27/generated/plan-doc/plan_summary.docx"
  ],
  "delegate_when": [
    "bounded read-only file inspection",
    "simple issue detection",
    "installation wait and polling work",
    "long-running log monitoring",
    "lightweight document verification"
  ],
  "direct_only_when": [
    "safety-critical or high-stakes work",
    "destructive operations",
    "credential handling",
    "cross-machine environment mutation without user approval"
  ],
  "token_budget_rules": [
    "Prefer compact JSON metadata before large rendered artifacts.",
    "Write shared task instructions here once, then have local agents read this file before acting."
  ]
}
